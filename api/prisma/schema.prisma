// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  phone             String?
  is_active         Boolean   @default(true)
  email_verified    Boolean   @default(false)
  email_verified_at DateTime?

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  user_roles      User_Role[]
  tournaments     Tournament[]
  seasons         Season[]
  tournamentRules TournamentRule[]
  teams           Team[]
  player          Player?
  teamPlayers     TeamPlayer[]
  seasonTeams     SeasonTeam[]
  matches         Match[]

  teamLeaders TeamLeader[]
  articles    Article[]

  @@map("users")
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  is_active   Boolean @default(true)

  created_at DateTime    @default(now())
  updated_at DateTime?   @updatedAt
  user_roles User_Role[]

  @@map("roles")
}

model User_Role {
  user    User @relation(fields: [user_id], references: [id])
  user_id Int
  role    Role @relation(fields: [role_id], references: [id])
  role_id Int

  @@id([user_id, role_id])
}

// ============================================================
// TOURNAMENT
// ============================================================

model Tournament {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  logo        String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime? @updatedAt

  deleted_at DateTime?

  seasons        Season[]
  user           User?           @relation(fields: [user_id], references: [id])
  user_id        Int?
  tournamentRule TournamentRule?

  @@map("tournaments")
}

model TournamentRule {
  id            Int       @id @default(autoincrement())
  tournament_id Int       @unique
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime? @updatedAt
  deleted_at    DateTime?

  // Scoring — không apply cho knockout phase
  points_per_win  Int @default(3)
  points_per_draw Int @default(1)
  points_per_loss Int @default(0)

  // Apply mọi phase format
  forfeit_score           Int  @default(3)
  yellow_cards_suspension Int  @default(3)
  max_players_per_team    Int  @default(11)
  min_players_per_team    Int  @default(7)
  // Chỉ apply cho round_robin phase
  teams_advance_per_group Int  @default(2)
  tiebreaker_order        Json @default("[\"goal_diff\",\"goals_scored\",\"head_to_head\"]")

  tournament Tournament @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [user_id], references: [id])
  user_id    Int?

  @@map("tournament_rules")
}

// ============================================================
// PHASE
// ============================================================

enum PhaseType {
  group_stage
  round_of_16
  quarter_final
  semi_final
  third_place
  final
}

enum PhaseFormat {
  round_robin
  knockout
}

enum PhaseStatus {
  draft
  in_progress
  locked
}

model Phase {
  id                     Int           @id @default(autoincrement())
  season_id              Int
  name                   String
  type                   PhaseType
  format                 PhaseFormat
  order                  Int
  start_date             DateTime?
  end_date               DateTime?
  min_rest_days_per_team Int           @default(3)
  is_active              Boolean       @default(true)
  legs                   Int           @default(1) // 1 = single-leg, 2 = two-legged
  bracket_slots          BracketSlot[]
  status                 PhaseStatus   @default(draft)

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  season  Season  @relation(fields: [season_id], references: [id], onDelete: Cascade)
  groups  Group[]
  matches Match[]

  @@map("phases")
}

model BracketSlot {
  id          Int  @id @default(autoincrement())
  phase_id    Int
  round       Int // 1 = first knockout round (R16/QF/...), max = log2(n)
  slot_number Int // 1-based position in round (determines pairing)
  match_id    Int? @unique // null until match is created (round 2+), or bye

  // Source slots: winner of source_a → home_team, winner of source_b → away_team
  // null = seeded team assigned directly (round 1), or bye slot
  source_a_slot_id Int?
  source_b_slot_id Int?

  // Seeded team IDs for round 1 slots (or bye slots)
  // Set at bracket generation time. null = not yet known (round 2+)
  seeded_home_team_id Int?
  seeded_away_team_id Int?

  is_bye Boolean @default(false) // true = one team advances automatically

  phase    Phase         @relation(fields: [phase_id], references: [id])
  match    Match?        @relation(fields: [match_id], references: [id])
  source_a BracketSlot?  @relation("SlotFeed_A", fields: [source_a_slot_id], references: [id])
  source_b BracketSlot?  @relation("SlotFeed_B", fields: [source_b_slot_id], references: [id])
  fed_as_a BracketSlot[] @relation("SlotFeed_A")
  fed_as_b BracketSlot[] @relation("SlotFeed_B")

  @@unique([phase_id, round, slot_number])
  @@map("bracket_slots")
}

// ============================================================
// SEASON
// ============================================================

enum SeasonStatus {
  upcoming
  registration_open
  ongoing
  finished
  cancelled
}

model Season {
  id                    Int          @id @default(autoincrement())
  name                  String       @unique
  description           String?
  status                SeasonStatus @default(upcoming)
  start_date            DateTime?
  end_date              DateTime?
  registration_deadline DateTime?
  max_teams             Int
  is_registration_open  Boolean      @default(false)
  is_active             Boolean      @default(true)
  created_at            DateTime     @default(now())
  updated_at            DateTime?    @updatedAt

  deleted_at       DateTime?
  registration_fee Decimal   @default(0) @db.Decimal(10, 2)

  tournament_id Int

  tournament Tournament @relation(fields: [tournament_id], references: [id], onDelete: Restrict)

  phases           Phase[]
  season_teams     SeasonTeam[]
  user             User?             @relation(fields: [user_id], references: [id])
  user_id          Int?
  playerStatistics PlayerStatistic[]
  notifications    Notification[]
  articles         Article[]

  @@map("seasons")
}

// ============================================================
// GROUP (chỉ dùng khi phase.format = round_robin)
// ============================================================
enum GroupStatus {
  DRAFT
  LOCKED
  SCHEDULED
  SCHEDULE_FAILED
}

model Group {
  id                  Int            @id @default(autoincrement())
  phase_id            Int
  name                String // "Bảng A", "Bảng B"
  is_active           Boolean        @default(true)
  created_at          DateTime       @default(now())
  updated_at          DateTime?      @updatedAt
  scheduleGeneratedAt DateTime?
  status              GroupStatus    @default(DRAFT)
  phase               Phase          @relation(fields: [phase_id], references: [id], onDelete: Cascade)
  matches             Match[]
  season_teams        SeasonTeam[]
  teamStandings       TeamStanding[]

  @@map("groups")
}

// ============================================================
// TEAM
// ============================================================

model Team {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  coach_name  String?
  logo        String?
  description String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime? @updatedAt

  deleted_at DateTime?

  team_players     TeamPlayer[]
  season_teams     SeasonTeam[]
  home_matches     Match[]           @relation("Match_homeTeam")
  away_matches     Match[]           @relation("Match_awayTeam")
  user             User?             @relation(fields: [user_id], references: [id])
  user_id          Int?
  teamLeaders      TeamLeader[]
  teamStandings    TeamStanding[]
  playerStatistics PlayerStatistic[]
  notifications    Notification[]
  matchResults     MatchResult[]
  articles         Article[]
  jerseys          TeamJersey[]
  matchLineups     MatchLineup[]

  @@map("teams")
}

model TeamJersey {
  id              Int        @id @default(autoincrement())
  team_id         Int
  type            JerseyType
  primary_color   String
  secondary_color String?
  team            Team       @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([team_id, type])
  @@map("team_jerseys")
}

enum JerseyType {
  home
  away
  third
  goalkeeper
}

// ============================================================
// PLAYER
// ============================================================

enum PlayerPosition {
  goalkeeper
  defender
  midfielder
  forward
}

model Player {
  id            Int            @id @default(autoincrement())
  date_of_birth DateTime
  position      PlayerPosition
  height        Decimal?       @db.Decimal(5, 2)
  weight        Decimal?       @db.Decimal(5, 2)
  nationality   String?
  avatar        String?
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime?      @updatedAt

  deleted_at DateTime?

  user_id Int  @unique
  user    User @relation(fields: [user_id], references: [id], onDelete: Restrict)

  team_players     TeamPlayer[]
  playerStatistics PlayerStatistic[]
  matchLineups     MatchLineup[]

  @@map("players")
}

// ============================================================
// TEAM PLAYER
// ============================================================

enum PlayerRole {
  player
  captain
  vice_captain
}

enum PlayerStatus {
  active
  injured
  suspended
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model TeamPlayer {
  id              Int            @id @default(autoincrement())
  team_id         Int
  player_id       Int
  jersey_number   Int
  position        PlayerPosition
  role            PlayerRole     @default(player)
  status          PlayerStatus   @default(active)
  approval_status ApprovalStatus @default(pending)
  is_active       Boolean        @default(true)
  created_at      DateTime       @default(now())
  updated_at      DateTime?      @updatedAt

  deleted_at DateTime?

  team   Team   @relation(fields: [team_id], references: [id], onDelete: Cascade)
  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  user    User? @relation(fields: [user_id], references: [id])
  user_id Int?

  @@unique([team_id, jersey_number])
  @@unique([team_id, player_id])
  @@map("team_players")
}

model TeamLeader {
  id         Int       @id @default(autoincrement())
  team_id    Int
  user_id    Int
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@map("team_leaders")
}

// ============================================================
// SEASON TEAM
// ============================================================

enum SeasonTeamStatus {
  approved
  pending
  active
  eliminated
  withdrawn
}

model SeasonTeam {
  id         Int                @id @default(autoincrement())
  season_id  Int
  team_id    Int
  status     SeasonTeamStatus   @default(pending)
  seed       Int?
  is_active  Boolean            @default(true)
  created_at DateTime           @default(now())
  jerseys    SeasonTeamJersey[]
  updated_at DateTime?          @updatedAt

  deleted_at DateTime?

  group_id Int?

  season Season @relation(fields: [season_id], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [team_id], references: [id], onDelete: Restrict)
  group  Group? @relation(fields: [group_id], references: [id], onDelete: SetNull)

  user     User?     @relation(fields: [user_id], references: [id])
  user_id  Int?
  payments Payment[]

  @@unique([season_id, team_id])
  @@map("season_teams")
}

model SeasonTeamJersey {
  id             Int @id @default(autoincrement())
  season_team_id Int

  type JerseyType

  primary_color   String
  secondary_color String?

  image_url String?

  season_team SeasonTeam @relation(fields: [season_team_id], references: [id], onDelete: Cascade)

  @@unique([season_team_id, type])
  @@map("season_team_jerseys")
}

model Venue {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  address    String?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  matches Match[]

  @@map("venues")
}

// ============================================================
// MATCH
// ============================================================
enum LineupType {
  starter
  substitute
}

enum MatchPlayerStatus {
  available
  injured
  suspended
  absent
}

model MatchLineup {
  id Int @id @default(autoincrement())

  match_id  Int
  team_id   Int
  player_id Int

  jersey_number Int
  position      PlayerPosition

  lineup_type LineupType @default(starter)

  is_captain Boolean @default(false)

  minute_in  Int?
  minute_out Int?

  status MatchPlayerStatus @default(available)

  created_at DateTime @default(now())

  match  Match  @relation(fields: [match_id], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [team_id], references: [id])
  player Player @relation(fields: [player_id], references: [id])

  @@unique([match_id, player_id])
  @@map("match_lineups")
}

enum MatchStatus {
  scheduled
  ongoing
  finished
  cancelled
  forfeited
  postponed
  bye
  abandoned
  pending_official
  needs_review
}

model Match {
  id                      Int              @id @default(autoincrement())
  phase_id                Int
  group_id                Int? // null = knockout
  home_team_id            Int
  away_team_id            Int
  scheduled_at            DateTime?
  played_at               DateTime?
  home_score              Int?
  away_score              Int?
  status                  MatchStatus      @default(scheduled)
  round                   String?
  leg                     Int? // 1 hoặc 2 nếu two-legged (knockout)
  current_period          MatchPeriod? // sub-state khi ongoing: extra_time_first, penalty_shootout...
  postponed_from          DateTime? // original scheduled_at
  postponed_reason        String?
  replay_of_match_id      Int? // self-ref: trận này là replay của trận nào
  abandoned_minute        Int? // abandoned tại phút mấy
  pending_official_at     DateTime?
  finalize_result_type    MatchResultType?
  finalize_home_half_time Int?
  finalize_away_half_time Int?
  finalize_home_penalty   Int?
  finalize_away_penalty   Int?
  manual_home_score       Int?
  manual_away_score       Int?
  is_active               Boolean          @default(true)
  created_at              DateTime         @default(now())
  updated_at              DateTime?        @updatedAt

  deleted_at DateTime?

  phase     Phase  @relation(fields: [phase_id], references: [id])
  group     Group? @relation(fields: [group_id], references: [id])
  home_team Team   @relation("Match_homeTeam", fields: [home_team_id], references: [id])
  away_team Team   @relation("Match_awayTeam", fields: [away_team_id], references: [id])

  events       MatchEvent[]
  user         User?         @relation(fields: [user_id], references: [id])
  user_id      Int?
  venue_id     Int?
  matchResult  MatchResult?
  venue        Venue?        @relation(fields: [venue_id], references: [id])
  is_published Boolean       @default(false)
  referee      String?
  articles     Article[]
  bracketSlot  BracketSlot?
  matchLineups MatchLineup[]

  @@unique([venue_id, scheduled_at])
  @@map("matches")
}

// ============================================================
// MATCH EVENT
// ============================================================

enum MatchEventType {
  goal
  own_goal
  yellow_card
  red_card
  second_yellow
  substitution_in
  substitution_out
  penalty_scored
  penalty_missed
  card_rescinded
  goal_disallowed
}

model MatchEvent {
  id                Int            @id @default(autoincrement())
  match_id          Int
  player_id         Int?
  team_id           Int?
  type              MatchEventType
  minute            Int?
  note              String?
  period            MatchPeriod?
  added_minute      Int?
  card_color        CardColor?
  sub_out_player_id Int?
  created_at        DateTime       @default(now())

  match Match @relation(fields: [match_id], references: [id], onDelete: Cascade)

  @@map("match_events")
}

enum CardColor {
  yellow
  red
}

enum MatchPeriod {
  first_half
  second_half
  extra_time_first
  extra_time_second
  penalty_shootout
}

enum MatchResultStatus {
  official
  protested
  overturned
  under_review
}

model TeamStanding {
  id             Int       @id @default(autoincrement())
  team_id        Int
  group_id       Int
  position       Int
  matches_played Int       @default(0)
  wins           Int       @default(0)
  draws          Int       @default(0)
  losses         Int       @default(0)
  goals_for      Int       @default(0)
  goals_against  Int       @default(0)
  points         Int       @default(0)
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime? @updatedAt
  deleted_at     DateTime?

  team  Team  @relation(fields: [team_id], references: [id], onDelete: Cascade)
  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([group_id, team_id])
  @@map("team_standings")
}

model PlayerStatistic {
  id                       Int       @id @default(autoincrement())
  player_id                Int
  team_id                  Int
  season_id                Int
  matches_played           Int       @default(0)
  goals_scored             Int       @default(0)
  assists                  Int       @default(0)
  yellow_cards             Int       @default(0)
  red_cards                Int       @default(0)
  minutes_played           Int       @default(0)
  accumulated_yellow_cards Int       @default(0)
  is_suspended             Boolean   @default(false)
  created_at               DateTime  @default(now())
  updated_at               DateTime? @updatedAt

  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [team_id], references: [id], onDelete: Cascade)
  season Season @relation(fields: [season_id], references: [id], onDelete: Cascade)

  @@unique([player_id, team_id, season_id])
  @@map("player_statistics")
}

enum MatchResultType {
  full_time
  extra_time
  penalty
  forfeit
  walkover
}

model MatchResult {
  id                    Int               @id @default(autoincrement())
  match_id              Int               @unique
  winner_team_id        Int?
  home_extra_time_score Int?
  away_extra_time_score Int?
  home_penalty_score    Int?
  away_penalty_score    Int?
  home_final_score      Int               @default(0)
  away_final_score      Int               @default(0)
  result_type           MatchResultType
  status                MatchResultStatus @default(official)
  duration              Int?
  notes                 String?           @db.Text
  appeal_reason         String?           @db.Text // + lý do protest
  appeal_note           String?           @db.Text // + resolution note (admin)
  is_active             Boolean           @default(true)
  created_at            DateTime          @default(now())
  updated_at            DateTime?         @updatedAt
  deleted_at            DateTime?

  match       Match @relation(fields: [match_id], references: [id], onDelete: Cascade)
  winner_team Team? @relation(fields: [winner_team_id], references: [id], onDelete: SetNull)

  @@map("match_results")
}

model Notification {
  id                Int                @id @default(autoincrement())
  title             String
  content           String             @db.Text
  type              NotificationType
  source            NotificationSource
  season_id         Int?
  target_team_id    Int?
  recipient_user_id Int?
  is_read           Boolean            @default(false)
  ref_entity_type   String?
  ref_entity_id     Int?
  is_active         Boolean            @default(true)
  created_at        DateTime           @default(now())
  updated_at        DateTime?          @updatedAt
  deleted_at        DateTime?

  season      Season? @relation(fields: [season_id], references: [id], onDelete: SetNull)
  target_team Team?   @relation(fields: [target_team_id], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model Payment {
  id                 Int           @id @default(autoincrement())
  season_team_id     Int
  amount             Decimal       @db.Decimal(10, 2)
  status             PaymentStatus @default(pending)
  transaction_ref    String?       @unique
  paid_at            DateTime?
  confirmed_at       DateTime?
  confirmed_by       Int?
  refunded_at        DateTime?
  refunded_by        Int?
  refund_amount      Decimal?
  vnp_transaction_no String?       @unique
  created_at         DateTime      @default(now())
  updated_at         DateTime?     @updatedAt

  season_team SeasonTeam @relation(fields: [season_team_id], references: [id], onDelete: Restrict)

  @@map("payments")
}

enum NotificationSource {
  manual
  system
}

enum NotificationType {
  match_schedule
  match_result
  standing_updated
  registration_deadline
  team_advanced
  payment_confirmed
  payment_rejected
  player_approved
  player_rejected
  team_approved
  team_rejected
  general
}

enum PaymentStatus {
  pending
  confirmed
  rejected
  refund_pending
  refunded
}

// Bảng 1: Bài viết
model Article {
  id          Int           @id @default(autoincrement())
  title       String
  slug        String        @unique
  content     String        @db.Text // CKEditor HTML output
  cover_image String? // Cloudinary URL
  status      ArticleStatus @default(draft)
  user_id     Int

  // Gắn với entity nào (optional)
  season_id Int?
  match_id  Int?
  team_id   Int?

  published_at DateTime?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime? @updatedAt
  deleted_at   DateTime?

  user   User    @relation(fields: [user_id], references: [id])
  season Season? @relation(fields: [season_id], references: [id])
  match  Match?  @relation(fields: [match_id], references: [id])
  team   Team?   @relation(fields: [team_id], references: [id])

  tags  ArticleTag[]
  media ArticleMedia[]

  @@map("articles")
}

enum ArticleStatus {
  draft
  published
  archived
}

// Bảng 2: Tags
model ArticleTag {
  id         Int    @id @default(autoincrement())
  article_id Int
  tag        String

  article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@unique([article_id, tag])
  @@map("article_tags")
}

// Bảng 3: Media attachments
model ArticleMedia {
  id         Int       @id @default(autoincrement())
  article_id Int
  type       MediaType
  url        String // Cloudinary URL (ảnh) | TBD (video)
  caption    String?
  order      Int       @default(0)
  created_at DateTime  @default(now())

  article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@map("article_media")
}

enum MediaType {
  image
  video
}
