// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  phone             String?
  is_active         Boolean   @default(true)
  email_verified    Boolean   @default(false)
  email_verified_at DateTime?

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  user_roles         User_Role[]
  tournaments        Tournament[]
  seasons            Season[]
  seasonRules        SeasonRule[]
  teams              Team[]
  player             Player?
  teamPlayers        TeamPlayer[]
  seasonTeams        SeasonTeam[]
  matches            Match[]
  // teams       Team[]
  passkeyCredentials PasskeyCredential[]
  oauthAccounts      OAuthAccount[]
  teamLeaders        TeamLeader[]

  @@map("users")
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  is_active   Boolean @default(true)

  created_at DateTime    @default(now())
  updated_at DateTime?   @updatedAt
  user_roles User_Role[]

  @@map("roles")
}

model User_Role {
  user    User @relation(fields: [user_id], references: [id])
  user_id Int
  role    Role @relation(fields: [role_id], references: [id])
  role_id Int

  @@id([user_id, role_id])
}

// ============================================================
// TOURNAMENT
// ============================================================

model Tournament {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  logo        String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime? @updatedAt

  deleted_at DateTime?

  seasons Season[]
  user    User?    @relation(fields: [user_id], references: [id])
  user_id Int?

  @@map("tournaments")
}

// ============================================================
// SEASON
// ============================================================

enum SeasonStatus {
  upcoming
  registration_open
  ongoing
  finished
  cancelled
}

model Season {
  id                    Int          @id @default(autoincrement())
  name                  String
  description           String?
  status                SeasonStatus @default(upcoming)
  start_date            DateTime
  end_date              DateTime
  registration_deadline DateTime
  max_teams             Int
  is_registration_open  Boolean      @default(false)
  is_active             Boolean      @default(true)
  created_at            DateTime     @default(now())
  updated_at            DateTime?    @updatedAt

  deleted_at DateTime?
  is_deleted Boolean   @default(false)

  tournament_id Int

  tournament Tournament @relation(fields: [tournament_id], references: [id], onDelete: Restrict)

  season_rule      SeasonRule?
  phases           Phase[]
  season_teams     SeasonTeam[]
  user             User?             @relation(fields: [user_id], references: [id])
  user_id          Int?
  playerStatistics PlayerStatistic[]
  notifications    Notification[]
  matches          Match[]

  @@map("seasons")
}

model SeasonRule {
  id         Int       @id @default(autoincrement())
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  created_by_id Int?
  updated_by_id Int?
  deleted_at    DateTime?
  deleted_by_id Int?
  is_deleted    Boolean   @default(false)

  season_id Int @unique

  points_per_win          Int     @default(3)
  points_per_draw         Int     @default(1)
  points_per_loss         Int     @default(0)
  yellow_cards_suspension Int     @default(3)
  max_players_per_team    Int     @default(25)
  min_players_per_team    Int     @default(11)
  registration_fee        Decimal @default(0) @db.Decimal(10, 2)
  forfeit_score           Int     @default(3)
  teams_advance_per_group Int     @default(2)
  // ["goal_diff","goals_scored","head_to_head","yellow_cards","draw"]
  tiebreaker_order        Json    @default("[\"goal_diff\",\"goals_scored\",\"head_to_head\"]")

  season  Season @relation(fields: [season_id], references: [id], onDelete: Cascade)
  user    User?  @relation(fields: [user_id], references: [id])
  user_id Int?

  @@map("season_rules")
}

// ============================================================
// PHASE
// ============================================================

enum PhaseType {
  group_stage
  round_of_16
  quarter_final
  semi_final
  third_place
  final
}

enum PhaseFormat {
  round_robin
  knockout
}

model Phase {
  id         Int         @id @default(autoincrement())
  season_id  Int
  name       String
  type       PhaseType
  format     PhaseFormat
  order      Int
  start_date DateTime?
  end_date   DateTime?
  is_active  Boolean     @default(true)
  created_at DateTime    @default(now())
  updated_at DateTime?   @updatedAt

  season  Season  @relation(fields: [season_id], references: [id], onDelete: Cascade)
  groups  Group[]
  matches Match[]

  @@map("phases")
}

// ============================================================
// GROUP (chỉ dùng khi phase.format = round_robin)
// ============================================================

model Group {
  id         Int       @id @default(autoincrement())
  phase_id   Int
  name       String // "Bảng A", "Bảng B"
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  phase         Phase          @relation(fields: [phase_id], references: [id], onDelete: Cascade)
  group_teams   GroupTeam[]
  matches       Match[]
  season_teams  SeasonTeam[]
  teamStandings TeamStanding[]

  @@map("groups")
}

model GroupTeam {
  group_id Int
  team_id  Int

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@id([group_id, team_id])
  @@map("group_teams")
}

// ============================================================
// TEAM
// ============================================================

model Team {
  id          Int       @id @default(autoincrement())
  name        String
  coach_name  String?
  logo        String?
  description String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime? @updatedAt

  deleted_at DateTime?
  is_deleted Boolean   @default(false)

  team_players     TeamPlayer[]
  season_teams     SeasonTeam[]
  home_matches     Match[]           @relation("Match_homeTeam")
  away_matches     Match[]           @relation("Match_awayTeam")
  group_teams      GroupTeam[]
  user             User?             @relation(fields: [user_id], references: [id])
  user_id          Int?
  teamLeaders      TeamLeader[]
  teamStandings    TeamStanding[]
  playerStatistics PlayerStatistic[]
  notifications    Notification[]
  matchResults     MatchResult[]

  @@map("teams")
}

// ============================================================
// PLAYER
// ============================================================

enum PlayerPosition {
  goalkeeper
  defender
  midfielder
  forward
}

model Player {
  id            Int            @id @default(autoincrement())
  date_of_birth DateTime
  position      PlayerPosition
  height        Decimal?       @db.Decimal(5, 2)
  weight        Decimal?       @db.Decimal(5, 2)
  nationality   String?
  avatar        String?
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime?      @updatedAt

  deleted_at DateTime?

  is_deleted Boolean @default(false)

  user_id Int  @unique
  user    User @relation(fields: [user_id], references: [id], onDelete: Restrict)

  team_players     TeamPlayer[]
  playerStatistics PlayerStatistic[]

  @@map("players")
}

// ============================================================
// TEAM PLAYER
// ============================================================

enum PlayerRole {
  player
  captain
  vice_captain
}

enum PlayerStatus {
  active
  injured
  suspended
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model TeamPlayer {
  id              Int            @id @default(autoincrement())
  team_id         Int
  player_id       Int
  jersey_number   Int
  position        PlayerPosition
  role            PlayerRole     @default(player)
  status          PlayerStatus   @default(active)
  approval_status ApprovalStatus @default(pending)
  is_active       Boolean        @default(true)
  created_at      DateTime       @default(now())
  updated_at      DateTime?      @updatedAt

  deleted_at DateTime?

  is_deleted Boolean @default(false)

  team   Team   @relation(fields: [team_id], references: [id], onDelete: Cascade)
  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  user              User?              @relation(fields: [user_id], references: [id])
  user_id           Int?
  seasonTeamPlayers SeasonTeamPlayer[]

  @@unique([team_id, jersey_number])
  @@unique([team_id, player_id])
  @@map("team_players")
}

// ============================================================
// SEASON TEAM
// ============================================================

enum SeasonTeamStatus {
  pending
  active
  eliminated
  withdrawn
}

model SeasonTeam {
  id              Int              @id @default(autoincrement())
  season_id       Int
  team_id         Int
  registered_date DateTime         @default(now())
  status          SeasonTeamStatus @default(pending)
  is_active       Boolean          @default(true)
  created_at      DateTime         @default(now())
  updated_at      DateTime?        @updatedAt

  deleted_at DateTime?

  is_deleted Boolean @default(false)

  group_id Int?

  season Season @relation(fields: [season_id], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [team_id], references: [id], onDelete: Restrict)
  group  Group? @relation(fields: [group_id], references: [id], onDelete: SetNull)

  user              User?              @relation(fields: [user_id], references: [id])
  user_id           Int?
  payments          Payment[]
  seasonTeamPlayers SeasonTeamPlayer[]

  @@unique([season_id, team_id])
  @@map("season_teams")
}

// ============================================================
// MATCH
// ============================================================

enum MatchStatus {
  scheduled
  ongoing
  finished
  cancelled
  forfeited
}

model Match {
  id            Int         @id @default(autoincrement())
  phase_id      Int
  group_id      Int? // null = knockout
  home_team_id  Int
  away_team_id  Int
  scheduled_at  DateTime?
  played_at     DateTime?
  home_score    Int?
  away_score    Int?
  status        MatchStatus @default(scheduled)
  round         String?
  leg           Int? // 1 hoặc 2 nếu two-legged (knockout)
  next_match_id Int? // winner tiến vào trận nào (knockout bracket)
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime?   @updatedAt

  deleted_at DateTime?

  is_deleted Boolean @default(false)

  phase     Phase  @relation(fields: [phase_id], references: [id])
  group     Group? @relation(fields: [group_id], references: [id])
  home_team Team   @relation("Match_homeTeam", fields: [home_team_id], references: [id])
  away_team Team   @relation("Match_awayTeam", fields: [away_team_id], references: [id])

  // Self-relation cho knockout progression
  next_match   Match?  @relation("Match_progression", fields: [next_match_id], references: [id])
  prev_matches Match[] @relation("Match_progression")

  events       MatchEvent[]
  user         User?        @relation(fields: [user_id], references: [id])
  user_id      Int?
  venue_id     Int?
  matchResult  MatchResult?
  venue        Venue?       @relation(fields: [venue_id], references: [id])
  is_published Boolean      @default(false)
  referee      String?
  season_id    Int?
  season       Season?      @relation(fields: [season_id], references: [id])

  @@map("matches")
}

// ============================================================
// MATCH EVENT
// ============================================================

enum MatchEventType {
  goal
  own_goal
  yellow_card
  red_card
  second_yellow
  substitution_in
  substitution_out
  penalty_scored
  penalty_missed
}

model MatchEvent {
  id                Int            @id @default(autoincrement())
  match_id          Int
  player_id         Int?
  team_id           Int?
  type              MatchEventType
  minute            Int?
  note              String?
  period            MatchPeriod?
  added_minute      Int?
  card_color        CardColor?
  sub_out_player_id Int?
  created_at        DateTime       @default(now())

  match Match @relation(fields: [match_id], references: [id], onDelete: Cascade)

  @@map("match_events")
}

enum CardColor {
  yellow
  red
}

enum MatchPeriod {
  first_half
  second_half
  extra_time_first
  extra_time_second
  penalty_shootout
}

enum MatchResultStatus {
  official
  protested
  overturned
}

enum MatchResultType {
  full_time
  extra_time
  penalty
  forfeit
  walkover
}

enum NotificationSource {
  manual
  system
}

enum NotificationType {
  match_schedule
  match_result
  standing_updated
  registration_deadline
  team_advanced
  payment_confirmed
  payment_rejected
  player_approved
  player_rejected
  team_approved
  team_rejected
  general
}

enum PaymentStatus {
  pending
  confirmed
  rejected
}

model PasskeyCredential {
  id                 Int       @id @default(autoincrement())
  user_id            Int
  device_id          String
  credential_id      String    @unique
  public_key         String    @db.Text
  sign_count         BigInt    @default(0)
  aaguid             String?
  is_backup_eligible Boolean   @default(false)
  is_backed_up       Boolean   @default(false)
  created_at         DateTime  @default(now())
  updated_at         DateTime? @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("passkey_credentials")
}

model OAuthAccount {
  id               Int       @id @default(autoincrement())
  user_id          Int
  provider         String
  provider_user_id String
  email            String
  email_verified   Boolean   @default(false)
  avatar_url       String?
  access_token     String?
  token_expires_at DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime? @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id])
  @@map("oauth_accounts")
}

model Venue {
  id         Int       @id @default(autoincrement())
  name       String
  address    String?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?
  is_deleted Boolean   @default(false)

  matches Match[]

  @@map("venues")
}

model TeamLeader {
  id         Int       @id @default(autoincrement())
  team_id    Int
  user_id    Int
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?
  is_deleted Boolean   @default(false)

  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@map("team_leaders")
}

model TeamStanding {
  id             Int       @id @default(autoincrement())
  team_id        Int
  group_id       Int
  position       Int
  matches_played Int       @default(0)
  wins           Int       @default(0)
  draws          Int       @default(0)
  losses         Int       @default(0)
  goals_for      Int       @default(0)
  goals_against  Int       @default(0)
  points         Int       @default(0)
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime? @updatedAt
  deleted_at     DateTime?
  is_deleted     Boolean   @default(false)

  team  Team  @relation(fields: [team_id], references: [id], onDelete: Cascade)
  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([group_id, team_id])
  @@map("team_standings")
}

model PlayerStatistic {
  id                       Int       @id @default(autoincrement())
  player_id                Int
  team_id                  Int
  season_id                Int
  matches_played           Int       @default(0)
  goals_scored             Int       @default(0)
  assists                  Int       @default(0)
  yellow_cards             Int       @default(0)
  red_cards                Int       @default(0)
  minutes_played           Int       @default(0)
  accumulated_yellow_cards Int       @default(0)
  is_suspended             Boolean   @default(false)
  created_at               DateTime  @default(now())
  updated_at               DateTime? @updatedAt

  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [team_id], references: [id], onDelete: Cascade)
  season Season @relation(fields: [season_id], references: [id], onDelete: Cascade)

  @@unique([player_id, team_id, season_id])
  @@map("player_statistics")
}

model Notification {
  id                Int                @id @default(autoincrement())
  title             String
  content           String             @db.Text
  type              NotificationType
  source            NotificationSource
  season_id         Int?
  target_team_id    Int?
  recipient_user_id Int?
  is_read           Boolean            @default(false)
  ref_entity_type   String?
  ref_entity_id     Int?
  is_active         Boolean            @default(true)
  created_at        DateTime           @default(now())
  updated_at        DateTime?          @updatedAt
  deleted_at        DateTime?
  is_deleted        Boolean            @default(false)

  season      Season? @relation(fields: [season_id], references: [id], onDelete: SetNull)
  target_team Team?   @relation(fields: [target_team_id], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model Payment {
  id              Int           @id @default(autoincrement())
  season_team_id  Int
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(pending)
  transaction_ref String?
  paid_at         DateTime?
  confirmed_at    DateTime?
  confirmed_by    Int?
  is_active       Boolean       @default(true)
  created_at      DateTime      @default(now())
  updated_at      DateTime?     @updatedAt
  deleted_at      DateTime?
  is_deleted      Boolean       @default(false)

  season_team SeasonTeam @relation(fields: [season_team_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model SeasonTeamPlayer {
  id             Int       @id @default(autoincrement())
  season_team_id Int
  team_player_id Int
  jersey_number  Int
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime? @updatedAt
  deleted_at     DateTime?
  is_deleted     Boolean   @default(false)

  season_team SeasonTeam @relation(fields: [season_team_id], references: [id], onDelete: Cascade)
  team_player TeamPlayer @relation(fields: [team_player_id], references: [id], onDelete: Cascade)

  @@unique([season_team_id, team_player_id])
  @@map("season_team_players")
}

model MatchResult {
  id                    Int               @id @default(autoincrement())
  match_id              Int               @unique
  winner_team_id        Int?
  home_score            Int               @default(0)
  away_score            Int               @default(0)
  home_half_time_score  Int               @default(0)
  away_half_time_score  Int               @default(0)
  home_extra_time_score Int?
  away_extra_time_score Int?
  home_penalty_score    Int?
  away_penalty_score    Int?
  home_final_score      Int               @default(0)
  away_final_score      Int               @default(0)
  result_type           MatchResultType
  status                MatchResultStatus @default(official)
  duration              Int?
  notes                 String?           @db.Text
  is_active             Boolean           @default(true)
  created_at            DateTime          @default(now())
  updated_at            DateTime?         @updatedAt
  deleted_at            DateTime?
  is_deleted            Boolean           @default(false)

  match       Match @relation(fields: [match_id], references: [id], onDelete: Cascade)
  winner_team Team? @relation(fields: [winner_team_id], references: [id], onDelete: SetNull)

  @@map("match_results")
}
