{
    "entryFile": "src/app.ts",
    "noImplicitAdditionalProperties": "throw-on-extras",
    "controllerPathGlobs": [
        "src/controllers/*.ts"
    ],
    "spec": {
        "securityDefinitions": {
            "jwt": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "outputDirectory": "src/generated",
        "specVersion": 3,
        "basePath": "/api/v1/",
        "info": {
            "title": "Football Management API",
            "version": "1.0.0"
        }
    },
    "routes": {
        "routesDir": "src/generated",
        "iocModule": "src/libs/ioc",
        "esm": true,
        "authenticationModule": "./src/middleware/auth.middleware.ts",
        "multerOpts": {
            "limits": {
                "fileSize": 5242880
            }
        }
    }
}